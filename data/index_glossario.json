ar o contencioso administrativo. Estados e Municípios têm representação paritária em sua instância máxima de deliberação, com alternância na presidência entre o conjunto dos Estados/DF e o conjunto dos Municípios/DF. É financiado por percentual do produto da arrecadação do próprio imposto e tem seu controle externo exercido pelos entes federativos.\nBase legal: Art. 156-B da Constituição Federal (incluído pela EC nº 132/2023); Lei Complementar nº 214/2025.","embedding":[-0.002,0.0351,0.0899,0.0676,-0.0345,-0.003,-0.0036,-0.0443,-0.0172,0.0272,0.0511,-0.0091,-0.0158,-0.0212,0.0322,-0.0319,-0.0446,0.0443,-0.0068,0.0409,-0.0064,-0.0125,-0.0346,0.0047,-0.0009,-0.0701,-0.0717,-0.003,-0.0189,0.0108,0.0804,-0.0006,0.0268,-0.0654,0.0108,0.0815,-0.051,0.0561,0.0548,0.0449,0.0538,-0.0109,-0.0166,-0.0734,-0.0633,-0.0018,0.0836,-0.0049,0.0064,0.021,0.0254,0.0927,0.0261,-0.0529,0.0086,0.0562,-0.0258,0.0623,-0.0191,-0.0511,0.013,-0.0328,0.0244,0.0013,-0.0729,0.0294,0.0294,0.0397,-0.0454,-0.037,-0.0663,0.1085,-0.0126,-0.1343,-0.0039,0.0019,0.0563,-0.0528,0.0193,-0.0181,-0.0424,0.0284,0.0122,0.0124,-0.0233,0.0083,-0.0381,0.0213,-0.0343,-0.0157,0.005,0.0159,-0.144,0.0369,0.0091,-0.0518,-0.0366,-0.0424,0.0332,-0.016,0.0707,0.0012,0.0488,0.019,0.0181,0.0828,-0.0355,-0.016,0.0422,0.0477,0.1237,-0.0276,0.0161,0.0542,-0.005,-0.043,-0.0421,0.0557,-0.0259,-0.0408,0.012,-0.0326,-0.0163,0.0271,0.0255,-0.0582,-0.0301,-0.0561,-0.0634,-0.0329,0.0527,-0.0251,-0.0062,-0.0126,-0.0596,0.0552,0.0081,0.015,-0.0024,-0.052,-0.0323,0.0553,0.0264,-0.0432,-0.0341,-0.0446,-0.1276,0.0074,0.0163,0.0371,0.0061,0.0187,-0.0086,0.004,-0.055,0.0015,-0.0546,0.0385,0.0618,0.0626,0.0095,-0.0014,0.0343,0.0192,-0.031,0.03,-0.0441,-0.0398,-0.0615,0.0462,-0.1078,-0.0308,-0.0323,0.028,-0.0485,-0.0496,0.0493,0.0581,0.1077,-0.0368,0.0079,-0.0109,-0.0524,0.0363,0.02,0.0806,0.0062,-0.0262,-0.0367,0.0614,0.0054,0.0267,0.0473,0.1425,0.0435,0.0215,-0.0503,0.0116,-0.0727,0.08,0.0041,0.001,-0.0184,0.0151,-0.0033,-0.0358,0.0548,0.