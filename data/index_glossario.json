 ser gradual e, em certas hipóteses definidas em regulamento, facultativa.\nBase legal: Arts. 31 a 35 da Lei Complementar nº 214/2025, com redação dada pela Lei Complementar nº 227/2026; Título V, Capítulo dos Tributos na Liquidação Financeira.","embedding":[0.0418,0.001,0.0507,0.0547,-0.033,-0.0173,-0.0398,-0.0469,-0.0021,-0.0252,0.0374,-0.0119,-0.0502,-0.0282,0.1128,0.0222,0.0142,0.0288,-0.0446,-0.0046,-0.0245,0.0079,0.0087,0.0396,-0.0295,-0.1383,-0.0715,-0.0516,-0.0525,-0.0264,0.1293,-0.0016,0.0216,-0.0402,-0.026,0.054,-0.0535,0.0459,0.0319,0.0325,-0.0349,0.0114,-0.0812,-0.0116,0.0057,0.0771,0.0445,-0.0493,0.0419,0.0682,-0.0097,0.0501,0.0609,-0.018,-0.0245,0.0113,-0.0241,0.0364,0.0106,-0.0558,-0.0179,-0.0349,-0.0155,-0.0649,-0.0491,0.0558,-0.0668,0.1062,-0.041,-0.0401,-0.0577,0.0602,-0.0289,-0.0397,0.0126,0.0433,0.0671,-0.0096,0.0659,-0.0291,-0.0206,-0.0548,-0.0327,0.0124,-0.0091,0.015,-0.1058,0.0396,-0.0659,0.0257,-0.0479,0.0003,-0.0762,0.0756,-0.0266,-0.0339,-0.0588,-0.0701,0.0128,0.0058,0.0215,-0.0095,0.0819,-0.0327,0.0485,0.011,-0.0016,-0.0421,-0.013,-0.0282,0.0864,0.0051,0.0119,0.0717,0.0674,-0.008,-0.0088,0.0352,-0.0523,-0.003,-0.0156,0.0286,-0.0509,-0.0744,0.0132,-0.0352,-0.0298,-0.032,-0.009,-0.0848,0.0842,-0.0009,0.0022,0.0085,-0.0041,0.0836,0.0433,0.0129,-0.0202,-0.053,-0.0294,0.0601,0.0778,-0.0067,-0.0348,0.0409,-0.0772,-0.0437,-0.0078,-0.0161,-0.0319,0.0043,-0.0105,0.0508,-0.0205,-0.0225,-0.0226,-0.0057,0.0467,0.0198,-0.0331,0.0141,0.0523,0.0811,-0.0195,-0.0244,-0.0107,-0.0003,-0.092,0.044,-0.0722,-0.0538,-0.0634,-0.0054,-0.0777,-0.025,0.063,-0.0053,0.084,-0.0475,-0.0136,-0.038,-0.0216,-0.0394,0.0136,0.0406,-0.0478,0.0363,-0.009,0.0611,0.005,-0.0038,0,0.0531,0.0214,0.0572,-0.0515,0.0087,-0.0562,-0.0133,-0.0027,0.0008,0.0037,0.0442,-0.0204,0.0539,-0.0181,0.0079,0.0075,-0.0177,0.0486,0.0356,-0.0537,0.0263,-0.0443,0.0578,-0.0153,0.0595,0.05,-0.029,0.0997,-0.0578,0.0293,0.0362,0.03,0.0323,0.0306,-0.0179,-0.0691,-0.0867,0.0397,0.0093,-0.0325,-0.0215,0.0382