# Copie este arquivo para ".env" (uso local) ou configure estas variáveis
# diretamente no painel da Vercel (Settings > Environment Variables).

# Chave da API da OpenAI (obtenha em https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Opcional. Modelo a usar. Se não definido, o código usa "gpt-5.6-terra".
# Confira os modelos disponíveis na sua conta em https://platform.openai.com/docs/models
OPENAI_MODEL=gpt-5.6-terra

# As variáveis abaixo só importam se você rodar scripts/build_index.js
# (geração do índice de busca / RAG). Os valores padrão já funcionam bem —
# só mude se souber o que está fazendo, e rode o script de novo depois.
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_EMBEDDING_DIMENSIONS=512
# RAG_TOP_K=8
